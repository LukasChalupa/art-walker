# Map tiles and optional Mapy.com route planning
VITE_MAPY_API_KEY=

# local = current cached OSM/Overpass graph planner
# mapy = use Mapy.com Routing API for walkable route geometry
VITE_ROUTING_PROVIDER=local

# Mapy route types for walking: foot_fast or foot_hiking
VITE_MAPY_ROUTE_TYPE=foot_fast

# Server-side AI shape recognition. Do not prefix these with VITE_.
AI_GATEWAY_API_KEY=
AI_SHAPE_MODEL=openai/gpt-4.1-mini

# Optional client overrides if your AI endpoints are hosted elsewhere.
# VITE_AI_SHAPE_API_URL=/api/ai-recognize-shapes
# VITE_AI_VECTOR_SHAPE_API_URL=/api/ai-generate-shapes
