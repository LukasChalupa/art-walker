# Map tiles and optional Mapy.com route planning
VITE_MAPY_API_KEY=

# local = current cached OSM/Overpass graph planner
# mapy = use Mapy.com Routing API for walkable route geometry
VITE_ROUTING_PROVIDER=local

# Mapy route types for walking: foot_fast or foot_hiking
VITE_MAPY_ROUTE_TYPE=foot_fast
